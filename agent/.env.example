# =============================================================================
# Agent environment configuration
# =============================================================================
# Copy this file to `agent/.env` and fill in real values.
# `agent/.env` is gitignored — never commit real credentials.
# =============================================================================

# --- Model provider (defaults to "nvidia") ----------------------------------
# Options: "nvidia" | "openrouter" | "openai"
MODEL_PROVIDER=nvidia

# --- NVIDIA (default provider) ----------------------------------------------
# Get a key at https://build.nvidia.com/ — model id must be one currently
# served by NVIDIA (e.g. meta/llama-3.3-70b-instruct).
NVIDIA_API_KEY=
NVIDIA_MODEL_NAME=meta/llama-3.3-70b-instruct
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# --- OpenRouter (also used for embeddings) ----------------------------------
# Required even when MODEL_PROVIDER=nvidia, because tools.py uses OpenRouter
# for query embeddings. Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL_NAME=meta-llama/llama-3.3-70b-instruct

# --- OpenAI (optional fallback) ---------------------------------------------
# OPENAI_API_KEY=
# OPENAI_MODEL_NAME=gpt-4o

# --- Qdrant (vector RAG) ----------------------------------------------------
# Local: http://localhost:6333 — Cloud: https://<cluster>.cloud.qdrant.io:6333
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=bac_production_vectors

# --- Neo4j (structured exam graph) ------------------------------------------
NEO4J_URI=neo4j+s://<your-instance>.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# --- Langsmith (optional tracing) -------------------------------------------
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=lemma-agent

# --- LangGraph checkpointing ------------------------------------------------
# Comment out POSTGRES_URI to fall back to in-memory MemorySaver.
# In docker-compose.dev.yml the postgres service is reachable as `postgres:5432`.
POSTGRES_URI=postgresql://langgraph:langgraph_dev_password@postgres:5432/langgraph_checkpoints

LANGGRAPH_ENV=development
